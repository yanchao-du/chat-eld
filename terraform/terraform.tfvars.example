# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — never commit it.

aws_profile   = "your-sso-profile-name"   # from `aws configure sso`
aws_region    = "ap-southeast-1"           # Singapore
instance_type = "t3.small"                 # t3.micro OOMs during pnpm install
key_pair_name = "your-key-pair-name"       # must exist in EC2 → Key Pairs
my_ip         = "1.2.3.4/32"              # run: curl ifconfig.me
project_name  = "nanoclaw-poc"
volume_size_gb = 20
